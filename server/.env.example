ESP_OFFLINE_THRESHOLD_MS=300000
PH_MIN=5.5
PH_MAX=6.5
BOIA_VAZIA_TIMEOUT_MIN=5
NIVEL_RESERVATORIO_ALERTA=20
TELEGRAM_BOT_TOKEN=
