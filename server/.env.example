# @module env
# @description Variaveis para producao real com Supabase, ESP e Telegram.
# @hardware esp32/esp8266
# @mode real

PORT=3001
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
